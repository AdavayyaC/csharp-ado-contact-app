<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <appSettings>
        <!-- 
            DATABASE CONFIGURATION (SQLite)
            ================================
            SQLite stores the database as a simple file — no server needed!
            The .db file will be created automatically in the app's directory.
        -->
        <add key="dataProvider" value="Microsoft.Data.Sqlite" />
        <add key="connectionString" value="Data Source=ContactDB.db" />
    </appSettings>
</configuration>
